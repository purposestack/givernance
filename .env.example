# =============================================================================
# Givernance — Local Development Environment
# Copy to .env and adjust as needed:  cp .env.example .env
# =============================================================================

# --- PostgreSQL -------------------------------------------------
# One Postgres instance, one logical database per tool (ADR-017).
# `givernance`           — application data (Drizzle-managed schema)
# `givernance_keycloak`  — Keycloak 24's internal tables, owned by `keycloak`
POSTGRES_DB=givernance
POSTGRES_USER=givernance
POSTGRES_PASSWORD=givernance_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://givernance:givernance_dev@localhost:5432/givernance
# App role for API (subject to RLS — do NOT use for workers/relay)
DATABASE_URL_APP=postgresql://givernance_app:givernance_app_dev@localhost:5432/givernance
# Keycloak's own database + owner role. Provisioned on first `docker compose
# up -d` by infra/postgres/init/01-init-keycloak-db.sh.
KEYCLOAK_DB_NAME=givernance_keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_dev

# --- Redis (cache / rate-limiting / BullMQ) ---------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Keycloak (OIDC / SAML) ------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Keycloak base URL and realm — consumed by the web app's server-side OIDC flow
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=givernance
# OIDC client credentials — must match infra/keycloak/realm-givernance.json
KEYCLOAK_CLIENT_ID=givernance-web
KEYCLOAK_CLIENT_SECRET=ci-test-secret-do-not-use-in-production
KEYCLOAK_ISSUER=http://localhost:8080/realms/givernance
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/givernance/protocol/openid-connect/certs
# Service-account client used by the API for Keycloak Admin API calls (ADR-016 / issue #107).
# `KEYCLOAK_ADMIN_URL` defaults to `KEYCLOAK_URL`; set it only when fronted separately.
# Leave `KEYCLOAK_ADMIN_CLIENT_SECRET` unset to disable the admin client (endpoints that
# need it will return a typed error rather than crash at boot).
KEYCLOAK_ADMIN_CLIENT_ID=givernance-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=ci-test-admin-secret-do-not-use-in-production
# KEYCLOAK_ADMIN_URL=http://localhost:8080

# --- Auth -------------------------------------------------------
# `KEYCLOAK_ISSUER` / `KEYCLOAK_JWKS_URL` are optional explicit overrides.
# Leave them aligned with the realm unless you front Keycloak elsewhere.

# --- Admin ------------------------------------------------------
# Secret header required for platform-admin routes (POST /v1/tenants, etc.)
ADMIN_SECRET=change-me-in-production

# --- MinIO (S3-compatible object storage) -----------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=givernance
MINIO_ROOT_PASSWORD=givernance_dev
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=givernance
S3_SECRET_ACCESS_KEY=givernance_dev
S3_REGION=fr-par
S3_RECEIPTS_BUCKET=receipts
S3_CAMPAIGNS_BUCKET=campaigns

# --- Mailpit (local SMTP testing) ------------------------------
# Browse sent mail at http://localhost:8025.
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
# Leave SMTP_USER / SMTP_PASS empty for Mailpit (it rejects AUTH).
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=Givernance <no-reply@givernance.local>

# --- App --------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug
# Public URL of the Next.js app — used by the API for CORS and by the web for OIDC redirects
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# API base URLs (ADR-011): internal server-to-server vs browser via public gateway
# API_URL uses 127.0.0.1 (not localhost) so Node's fetch/undici doesn't race IPv6
# ::1 against IPv4 127.0.0.1 — the API binds on 0.0.0.0 (IPv4 only), so ::1 fails.
API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Stripe Connect ---------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- Exchange rates ----------------------------------------------
# EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here

# --- Relay (outbox poller) --------------------------------------
OUTBOX_POLL_INTERVAL_MS=500

# --- NATS (Phase 4+, not required for local dev) ----------------
# NATS_URL=ws://localhost:4222
