{
  "name": "givernance",
  "version": "0.0.0",
  "private": true,
  "description": "Givernance — purpose-built CRM for European nonprofits. Modular monolith, GDPR-native, Salesforce alternative.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @givernance/api run db:generate",
    "db:migrate": "pnpm --filter @givernance/api run db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Onigam/givernance.git"
  },
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
