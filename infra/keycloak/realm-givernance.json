{
  "realm": "givernance",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "organizationsEnabled": true,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"org_id\",\"displayName\":\"Organization ID\",\"validations\":{\"length\":{\"min\":1,\"max\":64}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"multivalued\":false}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },
  "users": [
    {
      "username": "admin@givernance.org",
      "email": "admin@givernance.org",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Super",
      "lastName": "Admin",
      "attributes": {
        "org_id": ["00000000-0000-0000-0000-0000000000a1"],
        "role": ["org_admin"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["super_admin"]
    },
    {
      "username": "service-account-givernance-admin",
      "enabled": true,
      "serviceAccountClientId": "givernance-admin",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "manage-identity-providers",
          "query-users",
          "query-clients",
          "view-clients"
        ]
      }
    }
  ],
  "organizations": [
    {
      "name": "Givernance Platform",
      "alias": "platform",
      "description": "Seeded platform organization for the super-admin user (ADR-016 / issue #114). org_id attribute pins the platform tenant UUID (00000000-0000-0000-0000-0000000000a1) so it matches the tenants row seeded in the application DB. NEVER store secrets in organization attributes — Keycloak 26's oidc-organization-membership-mapper emits every attribute to every token on the default scopes.",
      "redirectUrl": "",
      "attributes": {
        "org_id": ["00000000-0000-0000-0000-0000000000a1"]
      },
      "domains": [
        { "name": "platform.givernance.invalid", "verified": true }
      ],
      "members": [
        { "username": "admin@givernance.org", "membershipType": "UNMANAGED" }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "super_admin",
        "description": "Givernance platform operator"
      },
      {
        "name": "org_admin",
        "description": "Tenant administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "givernance-admin",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "ci-test-admin-secret-do-not-use-in-production",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "description": "Service-account client for Keycloak Admin API calls from the Givernance backend (ADR-016 / issue #107). Scoped to realm-management roles: manage-realm, manage-users, manage-identity-providers, view-clients."
    },
    {
      "clientId": "givernance-web",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "ci-test-secret-do-not-use-in-production",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:3001/*"
      },
      "webOrigins": [
        "+"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email",
        "organization"
      ]
    }
  ]
}
