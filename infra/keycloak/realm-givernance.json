{
  "realm": "givernance",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "users": [
    {
      "username": "admin@givernance.org",
      "email": "admin@givernance.org",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Super",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["super_admin"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "super_admin",
        "description": "Givernance platform operator"
      },
      {
        "name": "org_admin",
        "description": "Tenant administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "givernance-web",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "ci-test-secret-do-not-use-in-production",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:3001/*"
      },
      "webOrigins": [
        "+"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    }
  ]
}
