flowchart TB
  subgraph Clients
    Browser["Browser / PWA"]
    VolPortal["Volunteer / Beneficiary Portal"]
  end

  subgraph Edge
    Caddy["Caddy\n(TLS + reverse proxy)"]
  end

  subgraph Application
    Web["givernance-web\n(Next.js 15 / React 19)"]
    API["givernance-api\n(Go 1.23)"]
    Worker["givernance-worker\n(Go 1.23, Asynq)"]
    Migrate["givernance-migrate\n(one-off ETL tool)"]
  end

  subgraph Infrastructure
    PgBouncer["PgBouncer 1.22\n(connection pooling)"]
    PG["PostgreSQL 16\n(primary datastore + RLS)"]
    PGReplica["PostgreSQL 16\n(read replica — reporting)"]
    Redis["Redis 7 / Valkey\n(job queue, cache, rate limit)"]
    NATS["NATS JetStream 2.10\n(event bus)"]
    MinIO["MinIO / S3\n(documents, receipts, exports)"]
  end

  subgraph Identity
    Keycloak["Keycloak 24\n(OIDC / SAML)"]
  end

  subgraph External
    Stripe["Stripe / Mollie\n(payments)"]
    Email["Resend / Brevo\n(email)"]
    Accounting["Xero / QuickBooks\n(GL push)"]
  end

  Browser --> Caddy
  VolPortal --> Caddy
  Caddy --> Web
  Caddy --> API

  Web -->|REST API| API
  Web -->|OIDC flow| Keycloak

  API --> PgBouncer
  PgBouncer --> PG
  PG -.->|WAL replication| PGReplica
  API --> Redis
  API -->|publish events| NATS
  API -->|presigned URLs| MinIO
  API -->|JWT validation| Keycloak
  API --> Stripe
  API --> Accounting

  Worker --> PgBouncer
  Worker --> Redis
  Worker -->|consume events| NATS
  Worker --> MinIO
  Worker --> Email

  Migrate -->|direct DB load| PG
  Migrate -->|read SF exports| MinIO
